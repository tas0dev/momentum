; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MOMENTUM"
run/main_scene="uid://bxc1tfkeafo7a"
run/print_header=false
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

CyclopsAutoload="*uid://4siqre3jhe80"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

movie_writer/movie_file="/home/jine/Videos/momentum.avi"
movie_writer/disable_vsync=true

[editor_plugins]

enabled=PackedStringArray("res://addons/cyclops_level_builder/plugin.cfg")

[global_group]

world_sun="ライトをビューモデルと同期する"
world_camera="カメラ"
hit_marker="ダメージを与えたりしたときに表示するやつ"

